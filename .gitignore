# Secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Pipeline cache (regeneratable from API; don't bloat the repo)
data/_raw/

# OS / editor
.DS_Store
.vscode/
.idea/

# Generated artifacts. We DO commit the small index/model files so the
# Streamlit app boots on a fresh clone (and on Streamlit Cloud) without
# needing a full rebuild. Larger transient files stay ignored.
models/*
!models/bm25.pkl
!models/faiss.index
!models/faiss_doc_ids.json
!models/ranker.pkl
!models/ranker.txt
!models/ranker_meta.json

# Phase 3 feature parquet (regenerable; ~1.6 MB; library-coupled binary format)
# features_meta.json IS committed - it documents the schema
data/features_*.parquet

# Phase 5 evaluation parquet (regenerable). eval_summary.json IS committed.
data/eval_results.parquet
